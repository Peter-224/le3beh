<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Admin Login</title>
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    body{background:#0d0d0d;color:#f0ece0;font-family:'Segoe UI',sans-serif;min-height:100vh;display:flex;align-items:center;justify-content:center}
    .box{background:#1a1a1a;border:0.5px solid rgba(255,255,255,0.15);border-radius:16px;padding:40px;width:100%;max-width:400px}
    h1{color:#c9a84c;font-size:24px;margin-bottom:8px}
    p{color:#a09880;font-size:14px;margin-bottom:24px}
    input{width:100%;background:#0d0d0d;border:0.5px solid rgba(255,255,255,0.15);border-radius:10px;padding:12px 14px;color:#f0ece0;font-size:15px;outline:none;margin-bottom:12px}
    input:focus{border-color:#c9a84c}
    button{width:100%;background:#c9a84c;color:#1a1200;border:none;border-radius:10px;padding:13px;font-size:15px;font-weight:700;cursor:pointer}
    button:hover{background:#e8c76d}
    .error{background:#2a0a0a;color:#ff8888;border:0.5px solid #cc3333;border-radius:8px;padding:10px 14px;font-size:13px;margin-bottom:12px}
  </style>
</head>
<body>
<div class="box">
  <h1>🎴 Admin Panel</h1>
  <p>Le3beh 3a Krouteh — Card Manager</p>
  <% if(error){ %><div class="error"><%= error %></div><% } %>
  <form method="POST" action="/admin/login">
    <input type="password" name="password" placeholder="Enter admin password" required autofocus/>
    <button type="submit">Login</button>
  </form>
</div>
</body>
</html>
